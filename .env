# Cloudinary configuration for client-side upload
VITE_CLOUDINARY_CLOUD_NAME=de5jdqth5
VITE_CLOUDINARY_UPLOAD_PRESET=clipgen_unsigned

# Optional: if you have a valid unsigned upload preset, enter it above.
# Otherwise leave VITE_CLOUDINARY_UPLOAD_PRESET blank and the frontend will use your backend signature endpoint.
# Set VITE_BACKEND_URL to your backend base URL if backend is not served from the same origin.
VITE_BACKEND_URL=http://localhost:8000